{
  "name": "pentaquest",
  "version": "1.0.0",
  "description": "PentaQuest - Endless turn-based dungeon",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "build": "npm run typecheck && node ./node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "cap:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:apk": "npm run build && npx cap sync android && powershell -Command \"Set-Location android; .\\gradlew.bat assembleDebug\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  }
}
